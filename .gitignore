# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
# ==========================
# Dependencies
# ==========================
node_modules/
.pnp
.pnp.js

# ==========================
# Next.js / Build Output
# ==========================
.next/
out/
build/
dist/

# ==========================
# Environment Variables (CRITICAL SECURITY)
# ==========================
# Never commit local environment files containing secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================
# Prisma
# ==========================
# Prisma Migrate history (optional, but good to ignore if you don't want to share DB migration SQL files)
prisma/migrations/ 

# ==========================
# Terraform (Infrastructure as Code)
# ==========================
# Ignore the .terraform directory (contains downloaded provider plugins)
.terraform/
.terraform.lock.hcl
terraform/

# Ignore Terraform state files (contains infrastructure state, sometimes sensitive data)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Ignore crash logs and override files
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore sensitive variable files
*.tfvars
!*.tfvars.example
#-------------------------------------------------------------
# Ignore the entire infrastructure/terraform directory content
/infrastructure/terraform/.terraform/
/infrastructure/terraform/.terraform.lock.hcl
/infrastructure/terraform/*.tfstate
/infrastructure/terraform/*.tfstate.*
/infrastructure/terraform/*.tfstate.backup
/infrastructure/terraform/crash.log
/infrastructure/terraform/override.tf
/infrastructure/terraform/override.tf.json
/infrastructure/terraform/*_override.tf
/infrastructure/terraform/*_override.tf.json
/infrastructure/terraform/*.tfvars
!/infrastructure/terraform/*.tfvars.example

# Also catch any terraform files in subdirectories
**/infrastructure/terraform/.terraform/
**/*.tfstate
**/*.tfvars

# Specifically for your secrets.tf file (should NEVER be committed)
/infrastructure/terraform/secrets.tf
# ==========================
# Docker
# ==========================
# We DO commit docker-compose.yml and Dockerfile so CI/CD can use them.
# But ignore any local docker volumes or data if you created any:
postgres_data/

# ==========================
# Testing & Coverage
# ==========================
coverage/
*.log

# ==========================
# OS & IDE Files
# ==========================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo